{
  "title": "flusso",
  "uid": "flusso",
  "tags": ["flusso"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Change throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(flusso_changes_captured_total[1m])",
          "legendFormat": "captured/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(flusso_changes_committed_total[1m])",
          "legendFormat": "committed/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "In-flight changes (back-pressure)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flusso_changes_in_flight",
          "legendFormat": "in flight",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Replication slot lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flusso_replication_slot_lag_bytes",
          "legendFormat": "lag",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Flush duration (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(flusso_flush_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Errors",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flusso_errors_total",
          "legendFormat": "errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Documents built",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (index) (rate(flusso_documents_built_total[1m]))",
          "legendFormat": "{{index}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Backlog drain ETA",
      "description": "Estimated time until the replication backlog is fully processed, at the current net drain rate. Shows 'not draining' when the backlog is flat or growing (no finite ETA).",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "not draining (flat or growing)",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 1800 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flusso:backlog_drain_eta_seconds",
          "legendFormat": "ETA",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Slot-lag trend (bytes/s; < 0 = draining)",
      "description": "Net rate of change of the slot lag. Negative means catching up, positive means falling behind, ~0 means keeping up in real time.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flusso:slot_lag_bytes_rate5m",
          "legendFormat": "lag change/s",
          "refId": "A"
        }
      ]
    }
  ]
}

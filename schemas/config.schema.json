{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pg_sync_rs Config",
  "type": "object",
  "required": ["source"],
  "additionalProperties": false,
  "definitions": {
    "pg_identifier": {
      "type": "string",
      "pattern": "^[a-z_][a-z0-9_]*$",
      "maxLength": 63
    }
  },
  "properties": {
    "source": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["postgres"]
        }
      }
    },
    "sinks": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/definitions/pg_identifier"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["opensearch", "stdout"]
          }
        }
      }
    },
    "index": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "schema", "enabled"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "$ref": "#/definitions/pg_identifier",
            "description": "Name of the index"
          },
          "schema": {
            "type": "string",
            "description": "Path to the index schema YAML file starting from the config location",
            "format": "uri-reference",
            "pattern": "^[^/][^:]*\\.ya?ml$"
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
